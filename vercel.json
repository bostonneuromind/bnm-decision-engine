{
  "version": 2,
  "builds": [
    { "src": "api/cna.py", "use": "@vercel/python", "config": { "includeFiles": "api/**" } },
    { "src": "api/beta_signup.py", "use": "@vercel/python", "config": { "includeFiles": "api/**" } },
    { "src": "api/get_signup.py", "use": "@vercel/python", "config": { "includeFiles": "api/**" } },
    { "src": "api/self_sign.py", "use": "@vercel/python", "config": { "includeFiles": "api/**" } },
    { "src": "api/parent_sign.py", "use": "@vercel/python", "config": { "includeFiles": "api/**" } },
    { "src": "api/feedback.py", "use": "@vercel/python", "config": { "includeFiles": "api/**" } },
    { "src": "api/admin_beta_list.py", "use": "@vercel/python", "config": { "includeFiles": "api/**" } },
    { "src": "api/admin_resend_email.py", "use": "@vercel/python", "config": { "includeFiles": "api/**" } },
    { "src": "api/consent_email.py", "use": "@vercel/python", "config": { "includeFiles": "api/**" } },
    { "src": "api/consent_get.py", "use": "@vercel/python", "config": { "includeFiles": "api/**" } },
    { "src": "api/consent_sign.py", "use": "@vercel/python", "config": { "includeFiles": "api/**" } },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/beta_signup", "dest": "/api/beta_signup.py" },
    { "src": "/api/get_signup", "dest": "/api/get_signup.py" },
    { "src": "/api/self_sign", "dest": "/api/self_sign.py" },
    { "src": "/api/parent_sign", "dest": "/api/parent_sign.py" },
    { "src": "/api/feedback", "dest": "/api/feedback.py" },
    { "src": "/api/admin_beta_list", "dest": "/api/admin_beta_list.py" },
    { "src": "/api/admin_resend_email", "dest": "/api/admin_resend_email.py" },
    { "src": "/api/consent_email", "dest": "/api/consent_email.py" },
    { "src": "/api/consent_get", "dest": "/api/consent_get.py" },
    { "src": "/api/consent_sign", "dest": "/api/consent_sign.py" },
    { "src": "/api/(.*)", "dest": "/api/cna.py" },
    { "src": "/(.*)/$", "dest": "/public/$1/index.html" },
    { "src": "/([^.]+)/?$", "dest": "/public/$1/index.html" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ],
  "env": {
    "PYTHONPATH": "api"
  }
}
